{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "quant-workspace://automated-research-factory/strategy-card-v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "strategy_card_id",
    "schema_version",
    "state",
    "hypothesis",
    "model_spec",
    "evidence",
    "boundary_flags"
  ],
  "properties": {
    "strategy_card_id": {
      "type": "string",
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "schema_version": {
      "const": "1.0"
    },
    "state": {
      "enum": [
        "BLOCKED",
        "RESEARCH_EVIDENCE_ACCEPTED",
        "RESEARCH_EVIDENCE_REJECTED"
      ]
    },
    "hypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question",
        "statement",
        "success_criteria",
        "failure_criteria"
      ],
      "properties": {
        "question": {
          "type": "string",
          "minLength": 1,
          "pattern": ".*\\S.*"
        },
        "statement": {
          "type": "string",
          "minLength": 1,
          "pattern": ".*\\S.*"
        },
        "success_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": ".*\\S.*"
          }
        },
        "failure_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": ".*\\S.*"
          }
        }
      }
    },
    "model_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "features_ref",
        "label_ref",
        "horizon",
        "universe_ref",
        "split_ref",
        "whole_label_split_purge",
        "parameter_budget_ref",
        "cost_model_ref",
        "gate_spec_ref"
      ],
      "properties": {
        "features_ref": {
          "$ref": "#/$defs/immutable_ref"
        },
        "label_ref": {
          "$ref": "#/$defs/immutable_ref"
        },
        "horizon": {
          "type": "string",
          "minLength": 1,
          "pattern": ".*\\S.*"
        },
        "universe_ref": {
          "$ref": "#/$defs/immutable_ref"
        },
        "split_ref": {
          "$ref": "#/$defs/immutable_ref"
        },
        "whole_label_split_purge": {
          "const": true
        },
        "parameter_budget_ref": {
          "$ref": "#/$defs/immutable_ref"
        },
        "cost_model_ref": {
          "$ref": "#/$defs/immutable_ref"
        },
        "gate_spec_ref": {
          "$ref": "#/$defs/immutable_ref"
        }
      }
    },
    "evidence": {
      "oneOf": [
        {
          "$ref": "#/$defs/blocked_evidence"
        },
        {
          "$ref": "#/$defs/accepted_evidence"
        },
        {
          "$ref": "#/$defs/rejected_evidence"
        }
      ]
    },
    "boundary_flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy_candidate_available",
        "readiness_promoted",
        "product_route_activated",
        "recommendation_runtime_enabled",
        "broker_api_allowed",
        "paper_trading_allowed",
        "live_trading_allowed",
        "auto_execution_allowed"
      ],
      "properties": {
        "strategy_candidate_available": {
          "const": false
        },
        "readiness_promoted": {
          "const": false
        },
        "product_route_activated": {
          "const": false
        },
        "recommendation_runtime_enabled": {
          "const": false
        },
        "broker_api_allowed": {
          "const": false
        },
        "paper_trading_allowed": {
          "const": false
        },
        "live_trading_allowed": {
          "const": false
        },
        "auto_execution_allowed": {
          "const": false
        }
      }
    }
  },
  "oneOf": [
    {
      "properties": {
        "state": {
          "const": "BLOCKED"
        },
        "evidence": {
          "$ref": "#/$defs/blocked_evidence"
        }
      }
    },
    {
      "properties": {
        "state": {
          "const": "RESEARCH_EVIDENCE_ACCEPTED"
        },
        "evidence": {
          "$ref": "#/$defs/accepted_evidence"
        }
      }
    },
    {
      "properties": {
        "state": {
          "const": "RESEARCH_EVIDENCE_REJECTED"
        },
        "evidence": {
          "$ref": "#/$defs/rejected_evidence"
        }
      }
    }
  ],
  "$defs": {
    "immutable_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "object_id",
        "sha256"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$"
        },
        "object_id": {
          "type": "string",
          "oneOf": [
            {
              "pattern": "^(?!([0-9a-f])\\1{39}$)[0-9a-f]{40}$"
            },
            {
              "pattern": "^(?!([0-9a-f])\\1{63}$)[0-9a-f]{64}$"
            },
            {
              "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
            },
            {
              "pattern": "^urn:sha256:(?!([0-9a-f])\\1{63}$)[0-9a-f]{64}$"
            }
          ]
        },
        "sha256": {
          "type": "string",
          "pattern": "^(?!([0-9a-f])\\1{63}$)[0-9a-f]{64}$"
        }
      }
    },
    "blocked_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "disposition",
        "review_ref",
        "prior_state",
        "actor",
        "decided_at",
        "reason"
      ],
      "properties": {
        "disposition": {
          "const": "BLOCKED"
        },
        "review_ref": {
          "$ref": "#/$defs/immutable_ref"
        },
        "prior_state": {
          "enum": [
            "NEW",
            "HYPOTHESIS",
            "MODEL_SPEC",
            "IMPLEMENTATION",
            "BACKTEST",
            "VERIFICATION",
            "FAILURE_REVIEW",
            "LOCKED_OOS"
          ]
        },
        "actor": {
          "type": "string",
          "minLength": 1,
          "pattern": ".*\\S.*"
        },
        "decided_at": {
          "type": "string",
          "format": "date-time"
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "pattern": ".*\\S.*"
        }
      }
    },
    "accepted_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "disposition",
        "review_ref",
        "reviewer",
        "decided_at",
        "reason",
        "verification_receipts",
        "metrics_ref",
        "reproducibility_ref",
        "multiple_testing_ref"
      ],
      "properties": {
        "disposition": {
          "const": "RESEARCH_EVIDENCE_ACCEPTED"
        },
        "review_ref": {
          "$ref": "#/$defs/immutable_ref"
        },
        "reviewer": {
          "type": "string",
          "minLength": 1,
          "pattern": ".*\\S.*"
        },
        "decided_at": {
          "type": "string",
          "format": "date-time"
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "pattern": ".*\\S.*"
        },
        "verification_receipts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/immutable_ref"
          }
        },
        "metrics_ref": {
          "$ref": "#/$defs/immutable_ref"
        },
        "reproducibility_ref": {
          "$ref": "#/$defs/immutable_ref"
        },
        "multiple_testing_ref": {
          "$ref": "#/$defs/immutable_ref"
        }
      }
    },
    "rejected_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "disposition",
        "review_ref",
        "reviewer",
        "decided_at",
        "reason",
        "failure_codes"
      ],
      "properties": {
        "disposition": {
          "const": "RESEARCH_EVIDENCE_REJECTED"
        },
        "review_ref": {
          "$ref": "#/$defs/immutable_ref"
        },
        "reviewer": {
          "type": "string",
          "minLength": 1,
          "pattern": ".*\\S.*"
        },
        "decided_at": {
          "type": "string",
          "format": "date-time"
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "pattern": ".*\\S.*"
        },
        "failure_codes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/failure_code"
          }
        },
        "evidence_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/immutable_ref"
          }
        }
      }
    },
    "failure_code": {
      "enum": [
        "DATA_GAP",
        "PIT_VIOLATION",
        "SURVIVORSHIP_BIAS",
        "LABEL_LEAKAGE",
        "SPLIT_PURGE_FAILURE",
        "EXECUTION_DELAY_MISSING",
        "CORPORATE_ACTION_MISSING",
        "COST_SLIPPAGE_MISSING",
        "REPRODUCIBILITY_FAILURE",
        "MULTIPLE_TESTING_UNDISCLOSED",
        "IMMUTABLE_REF_MISSING",
        "METRIC_INTEGRITY",
        "CONFIG_DRIFT",
        "SCOPE_BOUNDARY_VIOLATION",
        "OTHER_REQUIRES_REVIEW"
      ]
    }
  }
}
